<Project>
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest-recommended</AnalysisLevel>
    <CodeAnalysisTreatWarningsAsErrors>true</CodeAnalysisTreatWarningsAsErrors>
    <!-- Legacy package graph raises NU1510 under strict warnings-as-errors; tracked for dependency cleanup. -->
    <NoWarn>$(NoWarn);NU1510</NoWarn>

    <!-- Metadata -->
    <Authors>Fraser Molyneux</Authors>
    <Company>XtremeIdiots</Company>
    <Copyright>Copyright © Fraser Molyneux</Copyright>
    <RepositoryType>git</RepositoryType>

    <!-- SourceLink / symbols -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>
  
  <ItemGroup>
    <PackageReference Include="Nerdbank.GitVersioning" Version="3.9.50" PrivateAssets="all" />
  </ItemGroup>
</Project>
